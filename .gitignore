# ====================================================================
# MAVEN & BUILD SYSTEM
# ====================================================================
target/
*.class
*.war
*.ear
*.jar
*.nar
*.car
*.jacoco
.mvn/timing.properties
.mvn/wrapper/.maven-wrapper.properties

# Permite manter o jar do Maven Wrapper se você optar por usá-lo via terminal
!.mvn/wrapper/maven-wrapper.jar

# ====================================================================
# INTELLIJ IDEA (Ignora a pasta inteira para evitar conflitos de workspace)
# ====================================================================
.idea/
*.iml
*.iws
*.ipr
out/

# ====================================================================
# OUTRAS IDEs (VS Code, Eclipse, NetBeans)
# ====================================================================
.vscode/
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# ====================================================================
# SEGURANÇA & CONFIGURAÇÕES LOCAIS (Crucial para Spring Boot & PostgreSQL)
# ====================================================================
# Nunca envie suas senhas de banco de dados ou chaves JWT para o GitHub
.env
.env.local
.env.*.local
*.properties.local
*.yml.local

# ====================================================================
# FUTURE PROOFING: FRONTEND (React / Angular / Vue)
# ====================================================================
# Proteção para quando você criar a pasta do Front dentro do ecossistema
node_modules/
/dist
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ====================================================================
# SISTEMA OPERACIONAL
# ====================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db